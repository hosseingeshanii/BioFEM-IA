#!/usr/bin/env python3
"""biofem - BioFEM-IA solver CLI.

Subcommands:
  build   compile solver backends
  run     run solver (submits to SLURM when on a cluster)
  sweep   generate mesh cases and submit parameter sweep jobs
"""
__version__ = "0.1.0"

import argparse
import configparser
import os
import re
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

# ---------------------------------------------------------------------------
# Paths — detect whether running from source tree or installed location
#
#   Source tree:  bin/biofem  →  ../CMakeLists.txt exists
#   Installed:    ~/.local/bin/biofem  →  no CMakeLists.txt above us
# ---------------------------------------------------------------------------
_HERE      = Path(__file__).resolve().parent
_REPO_ROOT = _HERE.parent

_IN_SOURCE = (_REPO_ROOT / "CMakeLists.txt").exists()

if _IN_SOURCE:
    REPO_ROOT  = _REPO_ROOT
    BUILD_DIR  = REPO_ROOT / "build"
    CONFIG_DIR = REPO_ROOT / "config"
    # In the source tree executables may be named either way:
    #   cmake --build  → biofem-dmplex  (new)
    #   make dmplex    → testt-dmplex   (legacy)
    def _exe(cmake_name, legacy_name):
        p = BUILD_DIR / cmake_name
        return p if p.exists() else BUILD_DIR / legacy_name
else:
    REPO_ROOT  = None
    BUILD_DIR  = None
    CONFIG_DIR = _HERE.parent / "etc" / "biofem"   # optional installed config
    # Installed: executables are siblings in the same bin dir
    def _exe(cmake_name, _legacy):
        return _HERE / cmake_name

SITE_CFG = CONFIG_DIR / "site.cfg"

# load-env.sh lives at the repo root; for installed builds look one level up
# from the bin/ directory (i.e. <prefix>/load-env.sh).
if _IN_SOURCE:
    LOAD_ENV_SH = _REPO_ROOT / "load-env.sh"
else:
    _cand = _HERE.parent / "load-env.sh"
    LOAD_ENV_SH = _cand if _cand.exists() else None

BACKENDS = {
    "dmplex":        {"exe": _exe("biofem-dmplex",        "testt-dmplex"),        "gpu": False},
    "cuda":          {"exe": _exe("biofem-cuda",          "testt-cuda"),          "gpu": True},
    "kokkos-cuda":   {"exe": _exe("biofem-kokkos-cuda",   "testt-kokkos-cuda"),   "gpu": True},
    "kokkos-openmp": {"exe": _exe("biofem-kokkos-openmp", "testt-kokkos-openmp"), "gpu": False},
}

# Lazy-guard numpy/scipy so build/run work without them installed.
try:
    import numpy as np
    from scipy.spatial import Delaunay as _Delaunay
    HAS_MESH_DEPS = True
except ImportError:
    HAS_MESH_DEPS = False


# ---------------------------------------------------------------------------
# Site config (config/site.cfg, gitignored, created by setup.sh)
# ---------------------------------------------------------------------------
def load_site_config() -> configparser.ConfigParser:
    cfg = configparser.ConfigParser()
    cfg.read_dict({
        "slurm":   {"account": "", "partition": ""},
        "modules": {"base": "", "petsc": "", "cuda": ""},
        "mpi":     {"extra_flags": ""},
    })
    if SITE_CFG.exists():
        cfg.read(SITE_CFG)
    return cfg


def _module_lines(cfg: configparser.ConfigParser, *, cuda: bool) -> str:
    mods = []
    for key in ("base", "petsc"):
        val = cfg.get("modules", key, fallback="").strip()
        if val:
            mods.extend(val.split())
    if cuda:
        val = cfg.get("modules", "cuda", fallback="").strip()
        if val:
            mods.extend(val.split())
    if not mods:
        return ""
    return "module purge\n" + "\n".join(f"ml {m}" for m in mods)


def _load_env_line() -> str:
    """Return a shell line that sources load-env.sh, or empty string if not found."""
    if LOAD_ENV_SH and LOAD_ENV_SH.exists():
        return f"source {LOAD_ENV_SH}"
    return ""


# ---------------------------------------------------------------------------
# Cluster detection
# ---------------------------------------------------------------------------
def detect_cluster() -> dict:
    return {
        "has_slurm":      shutil.which("sbatch") is not None,
        "in_allocation":  bool(os.environ.get("SLURM_JOB_ID")),
        "has_gpu":        (
            bool(os.environ.get("CUDA_VISIBLE_DEVICES"))
            or shutil.which("nvidia-smi") is not None
        ),
    }


# ---------------------------------------------------------------------------
# Jobfile builders
# ---------------------------------------------------------------------------
def _run_jobfile(
    *, backend, executable, run_dir, np, time, account,
    mpi_flags, load_env, gpu, petsc_opts="", slurm_output="",
) -> str:
    acct_line   = f"#SBATCH --account={account}" if account else ""
    gpu_line    = "#SBATCH --gpus=1" if gpu else ""
    output_line = f"#SBATCH --output={slurm_output}" if slurm_output else f"#SBATCH --output=biofem_{backend}_%j.out"
    ntasks      = 1 if gpu else np
    env_block   = load_env if load_env else "# no load-env.sh found"
    exe_str     = f"{executable}{(' ' + petsc_opts) if petsc_opts else ''}"
    if gpu:
        mpi_cmd = f'/usr/bin/time -f "BENCH_WALL_SECONDS=%e" \\\n  {exe_str}'
    else:
        mpi_extra = f" {mpi_flags}" if mpi_flags.strip() else ""
        mpi_cmd = (
            f'/usr/bin/time -f "BENCH_WALL_SECONDS=%e" \\\n'
            f'  mpirun -np "${{SLURM_NTASKS:-{np}}}"{mpi_extra} {exe_str}'
        )
    return (
        f"#!/bin/bash\n"
        f"#SBATCH --job-name=biofem-{backend}\n"
        f"#SBATCH --time={time}\n"
        f"#SBATCH --ntasks={ntasks}\n"
        f"#SBATCH --cpus-per-task=1\n"
        f"#SBATCH --mem=8G\n"
        f"{output_line}\n"
        f"{gpu_line}\n"
        f"{acct_line}\n"
        f"\nset -euo pipefail\n"
        f"\n{env_block}\n"
        f'\ncd "{run_dir}" || exit 1\n'
        f'\necho "BENCH_TIME_LIMIT={time}"\n'
        f"\n{mpi_cmd}\n"
    )


def _sweep_jobfile(
    *, backend, executable, case_dir, nx, ny, ntasks, nnodes, nelems,
    time, memory, account, mpi_flags, load_env, gpu,
) -> str:
    acct_line = f"#SBATCH --account={account}" if account else ""
    gpu_line  = "#SBATCH --gpus=1" if gpu else ""
    env_block = load_env if load_env else "# no load-env.sh found"
    if gpu:
        mpi_cmd = f'/usr/bin/time -f "BENCH_WALL_SECONDS=%e" \\\n  {executable}'
    else:
        mpi_extra = f" {mpi_flags}" if mpi_flags.strip() else ""
        mpi_cmd = (
            f'/usr/bin/time -f "BENCH_WALL_SECONDS=%e" \\\n'
            f'  mpirun -np "${{SLURM_NTASKS:-{ntasks}}}"{mpi_extra} {executable}'
        )
    return (
        f"#!/bin/bash\n"
        f"#SBATCH --job-name={backend}_mesh_nx{nx}_ny{ny}_np{ntasks}\n"
        f"#SBATCH --time={time}\n"
        f"#SBATCH --ntasks={ntasks}\n"
        f"#SBATCH --cpus-per-task=1\n"
        f"#SBATCH --mem={memory}\n"
        f"#SBATCH --output=out_{backend}_nx{nx}_ny{ny}_np{ntasks}\n"
        f"{gpu_line}\n"
        f"{acct_line}\n"
        f"\nset -euo pipefail\n"
        f"\n{env_block}\n"
        f'\ncd "{case_dir}" || exit 1\n'
        f'\necho "BENCH_BACKEND={backend}"\n'
        f'echo "BENCH_MESH_NX={nx}"\n'
        f'echo "BENCH_MESH_NY={ny}"\n'
        f'echo "BENCH_NODES={nnodes}"\n'
        f'echo "BENCH_ELEMENTS={nelems}"\n'
        f'echo "BENCH_NTASKS=${{SLURM_NTASKS:-{ntasks}}}"\n'
        f'echo "BENCH_JOB_ID=${{SLURM_JOB_ID:-local}}"\n'
        f'echo "BENCH_TIME_LIMIT={time}"\n'
        f"\n{mpi_cmd}\n"
    )


# ---------------------------------------------------------------------------
# run
# ---------------------------------------------------------------------------
def cmd_run(args):
    info = BACKENDS[args.backend]
    executable = info["exe"]
    if not executable.exists():
        print(f"[biofem] Executable not found: {executable}", file=sys.stderr)
        print(f"         Run: biofem build --backend {args.backend}", file=sys.stderr)
        sys.exit(1)

    run_dir = Path.cwd()
    if not (run_dir / "control.dat").exists():
        print("[biofem] No control.dat found in current directory.", file=sys.stderr)
        print("         cd into a case directory before running.", file=sys.stderr)
        sys.exit(1)

    cfg       = load_site_config()
    cluster   = detect_cluster()
    account   = args.account or cfg.get("slurm", "account", fallback="")
    mpi_flags = cfg.get("mpi", "extra_flags", fallback="")
    load_env  = _load_env_line()

    # Build extra PETSc options from --monitor and --petsc-opts
    monitors = [m.strip() for m in args.monitor.split(",") if m.strip()]
    petsc_opts_parts = []
    if "residual" in monitors:
        petsc_opts_parts.append("-monitor_residual 1")
    if args.petsc_opts.strip():
        petsc_opts_parts.append(args.petsc_opts.strip())
    petsc_opts = " ".join(petsc_opts_parts)

    # Resolve the output directory, matching PETSc option precedence:
    # command-line (--petsc-opts) > control.dat > hardcoded default "output".
    def _parse_out_dir(tokens):
        for i, t in enumerate(tokens):
            if t == "-out_dir" and i + 1 < len(tokens):
                return tokens[i + 1]
        return None

    out_dir = (
        _parse_out_dir(petsc_opts.split())           # 1. command-line wins
        or _parse_out_dir(                            # 2. control.dat
            [tok for line in (run_dir / "control.dat").read_text(errors="replace").splitlines()
             for tok in line.split()
             if not line.lstrip().startswith("#")]
        )
        or "output"                                   # 3. default
    )

    # --local forces a direct terminal run regardless of SLURM availability.
    # Otherwise submit via sbatch when on a cluster and not in an allocation
    # (or when a GPU backend is requested, which always needs a dedicated node).
    if args.local:
        use_sbatch = False
    else:
        use_sbatch = cluster["has_slurm"] and (info["gpu"] or not cluster["in_allocation"])

    if use_sbatch:
        if not account:
            print("[biofem] Warning: no SLURM account set. Job may be rejected.", file=sys.stderr)
            print("         Pass --account YOUR_ACCOUNT, or set it in config/site.cfg", file=sys.stderr)
        jf = _run_jobfile(
            backend=args.backend, executable=executable, run_dir=run_dir,
            np=args.np, time=args.time, account=account,
            mpi_flags=mpi_flags, load_env=load_env, gpu=info["gpu"],
            petsc_opts=petsc_opts, slurm_output=args.slurm_output,
        )
        if args.dry_run:
            print(jf)
            return
        with tempfile.NamedTemporaryFile("w", suffix=".slurm", delete=False, dir=run_dir) as f:
            f.write(jf)
            tmp = Path(f.name)
        want_monitor = "residual" in monitors
        sbatch_cmd = ["sbatch"]
        if args.wait or want_monitor:
            # --wait is required for live monitoring (we need sbatch to block
            # so we can poll residual.log while the job runs on the compute node)
            sbatch_cmd.append("--wait")
        sbatch_cmd.append(str(tmp))
        try:
            if want_monitor:
                # Pass the sbatch command into _run_with_monitor so it polls
                # output/residual.log (on the shared filesystem) while the job
                # runs — same live plot + final PNG save as for local runs.
                sbatch_shell = " ".join(str(s) for s in sbatch_cmd)
                _run_with_monitor(sbatch_shell, run_dir, args.port, out_dir)
            else:
                subprocess.run(sbatch_cmd, cwd=run_dir, check=True)
        finally:
            tmp.unlink(missing_ok=True)
        if want_monitor and not args.wait:
            # job already finished (--wait was added implicitly above), nothing extra to do
            pass
    else:
        # Build the mpi command parts
        mpi_extra     = mpi_flags.split() if mpi_flags.strip() else []
        petsc_opts_list = petsc_opts.split() if petsc_opts else []
        cmd_parts = ["mpirun", "-np", str(args.np)] + mpi_extra + [str(executable)] + petsc_opts_list
        cmd_str   = " ".join(cmd_parts)

        # Prepend environment setup so the solver sees the right modules
        if load_env:
            shell_cmd = f"{load_env} && {cmd_str}"
        else:
            shell_cmd = cmd_str

        if args.dry_run:
            print(shell_cmd)
            return

        print(f"[biofem] running locally: {cmd_str}")
        if "residual" in monitors:
            _run_with_monitor(shell_cmd, run_dir, args.port, out_dir)
        else:
            subprocess.run(["bash", "--login", "-c", shell_cmd], cwd=run_dir, check=True)


# ---------------------------------------------------------------------------
# sweep
# ---------------------------------------------------------------------------
FAIL_PATTERNS = ("PETSC ERROR", "Killed", "signal 9", "non-zero exit code")
_ITER1_RE     = re.compile(r"\[iter\s+1\]")


def _sweep_resources(nx: int, ny: int) -> tuple[str, str]:
    n = nx * ny
    if n <= 48  * 36:  return "00:30:00", "4G"
    if n <= 128 * 96:  return "01:00:00", "8G"
    if n <= 256 * 192: return "02:00:00", "16G"
    if n <= 384 * 288: return "04:00:00", "32G"
    if n <= 512 * 384: return "06:00:00", "64G"
    return "08:00:00", "128G"


def _out_failed(case_dir, backend, nx, ny, ntasks) -> bool:
    p = case_dir / f"out_{backend}_nx{nx}_ny{ny}_np{ntasks}"
    return p.exists() and any(pat in p.read_text(errors="replace") for pat in FAIL_PATTERNS)


def _out_done(case_dir, backend, nx, ny, ntasks) -> bool:
    p = case_dir / f"out_{backend}_nx{nx}_ny{ny}_np{ntasks}"
    return p.exists() and bool(_ITER1_RE.search(p.read_text(errors="replace")))


def cmd_sweep(args):
    if not HAS_MESH_DEPS:
        print("[biofem] numpy and scipy are required for sweep mesh generation.", file=sys.stderr)
        print("         Load the python/scipy module or: pip install numpy scipy", file=sys.stderr)
        sys.exit(1)

    info = BACKENDS[args.backend]
    executable = info["exe"]
    if not executable.exists():
        print(f"[biofem] Executable not found: {executable}", file=sys.stderr)
        print(f"         Run: biofem build --backend {args.backend}", file=sys.stderr)
        sys.exit(1)

    if not shutil.which("sbatch"):
        print("[biofem] sbatch not found. Sweep requires SLURM to submit jobs.", file=sys.stderr)
        print("         Use --dry-run to preview generated jobfiles.", file=sys.stderr)
        if not args.dry_run:
            sys.exit(1)

    cfg       = load_site_config()
    account   = args.account or cfg.get("slurm", "account", fallback="")
    mpi_flags = cfg.get("mpi", "extra_flags", fallback="")
    load_env  = _load_env_line()

    if not account:
        print("[biofem] Warning: no SLURM account set. Jobs may be rejected.", file=sys.stderr)
        print("         Pass --account YOUR_ACCOUNT, or set it in config/site.cfg", file=sys.stderr)

    nx_list = [int(x) for x in args.nx.split(",")]
    ny_list = [int(x) for x in args.ny.split(",")]
    if len(nx_list) != len(ny_list):
        print("[biofem] --nx and --ny must have the same number of values.", file=sys.stderr)
        sys.exit(1)

    ntasks_list = [int(x) for x in args.ntasks.split(",")]
    lx, ly      = args.lx, args.ly
    output_dir  = Path(args.output_dir).resolve()
    output_dir.mkdir(parents=True, exist_ok=True)

    template_ctrl = REPO_ROOT / "examples" / "dmplex_test" / "control.dat"
    if not template_ctrl.exists():
        print(f"[biofem] Template control.dat not found: {template_ctrl}", file=sys.stderr)
        sys.exit(1)

    print(f"[biofem] sweep  backend={args.backend}  cases={len(nx_list)}  ntasks={ntasks_list}")
    print(f"[biofem] output {output_dir}")

    submitted = skipped = 0

    for nx, ny in zip(nx_list, ny_list):
        case_dir = output_dir / f"mesh_Lx{lx}_Ly{ly}_nx{nx}_ny{ny}"
        case_dir.mkdir(exist_ok=True)
        (case_dir / "input").mkdir(exist_ok=True)
        (case_dir / "output").mkdir(exist_ok=True)

        pts, tri = _build_mesh(lx, ly, nx, ny)
        nnodes, nelems = pts.shape[0], tri.shape[0]
        edges = _boundary_node_lists(pts, lx, ly)
        _write_nlist(case_dir / "input" / "nlist00", pts)
        _write_elist(case_dir / "input" / "elist00", tri)
        _write_blist(case_dir / "input" / "blist00", edges)
        shutil.copy2(template_ctrl, case_dir / "control.dat")

        time_limit, memory = _sweep_resources(nx, ny)

        for ntasks in ntasks_list:
            approx_elems = 2 * nx * ny
            if approx_elems // ntasks < args.min_elems_per_task:
                print(f"  skip  {case_dir.name}  np={ntasks}  (~{approx_elems // ntasks} elems/task)")
                skipped += 1
                continue
            if args.failed_only and not _out_failed(case_dir, args.backend, nx, ny, ntasks):
                skipped += 1
                continue
            if not args.rerun_completed and _out_done(case_dir, args.backend, nx, ny, ntasks):
                print(f"  done  {case_dir.name}  np={ntasks}  (skip)")
                skipped += 1
                continue

            jf = _sweep_jobfile(
                backend=args.backend, executable=executable,
                case_dir=case_dir, nx=nx, ny=ny, ntasks=ntasks,
                nnodes=nnodes, nelems=nelems,
                time=time_limit, memory=memory, account=account,
                mpi_flags=mpi_flags, load_env=load_env, gpu=info["gpu"],
            )
            jobfile = case_dir / f"jobfile_np{ntasks}.slurm"
            jobfile.write_text(jf)

            if args.dry_run:
                print(f"  dry   {case_dir.name}  np={ntasks}  {jobfile}")
                submitted += 1
                continue

            result = subprocess.run(
                ["sbatch", jobfile.name], cwd=case_dir, text=True, capture_output=True,
            )
            msg = result.stdout.strip() or result.stderr.strip()
            if result.returncode != 0:
                print(f"  ERROR {case_dir.name}  np={ntasks}  {msg}", file=sys.stderr)
                sys.exit(result.returncode)
            print(f"  sub   {case_dir.name}  np={ntasks}  {msg}")
            submitted += 1

    print(f"\n[biofem] {submitted} submitted, {skipped} skipped.")


# ---------------------------------------------------------------------------
# Mesh generation (rectangular Delaunay with boundary-edge fix)
# ---------------------------------------------------------------------------
def _build_mesh(lx: float, ly: float, nx: int, ny: int):
    x = np.linspace(0.0, lx, nx)
    y = np.linspace(0.0, ly, ny)
    X, Y = np.meshgrid(x, y, indexing="xy")
    pts  = np.column_stack([X.ravel(), Y.ravel()])
    tri  = _Delaunay(pts).simplices.astype(np.int64)
    return _fix_two_boundary_edge_tris(pts, tri, lx, ly)


def _on_boundary_edge(pts, i, j, lx, ly, tol=1e-10) -> bool:
    pi, pj = pts[i], pts[j]
    return any([
        abs(pi[0])      <= tol and abs(pj[0])      <= tol,
        abs(pi[0] - lx) <= tol and abs(pj[0] - lx) <= tol,
        abs(pi[1])      <= tol and abs(pj[1])      <= tol,
        abs(pi[1] - ly) <= tol and abs(pj[1] - ly) <= tol,
    ])


def _orient2(a, b, c) -> float:
    return (b[0] - a[0]) * (c[1] - a[1]) - (b[1] - a[1]) * (c[0] - a[0])


def _split_edge(pts, tri, u, v, midmap: dict):
    key = (min(u, v), max(u, v))
    if key not in midmap:
        midmap[key] = pts.shape[0]
        pts = np.vstack([pts, 0.5 * (pts[u] + pts[v])[None, :]])
    m = midmap[key]

    new_tris = []
    for t in tri:
        if u in t and v in t:
            r       = next(x for x in t if x != u and x != v)
            a, b, c = t
            sgn     = _orient2(pts[a], pts[b], pts[c])
            t1, t2  = (u, m, r), (m, v, r)
            if sgn != 0:
                if _orient2(pts[t1[0]], pts[t1[1]], pts[t1[2]]) * sgn < 0:
                    t1 = (u, r, m)
                if _orient2(pts[t2[0]], pts[t2[1]], pts[t2[2]]) * sgn < 0:
                    t2 = (m, r, v)
            new_tris += [t1, t2]
        else:
            new_tris.append(tuple(t))
    return pts, np.array(new_tris, dtype=np.int64)


def _fix_two_boundary_edge_tris(pts, tri, lx, ly, tol=1e-10, max_passes=1000):
    midmap: dict = {}
    for _ in range(max_passes):
        to_split = None
        for t in tri:
            a, b, c = t
            bedges = [(i, j) for i, j in [(a, b), (b, c), (c, a)]
                      if _on_boundary_edge(pts, i, j, lx, ly, tol)]
            if len(bedges) == 2:
                (u1, v1), (u2, v2) = bedges
                shared = next((x for x in (u1, v1) if x in (u2, v2)), None)
                if shared is None:
                    continue
                others = [x for x in (a, b, c) if x != shared]
                if len(others) == 2:
                    to_split = tuple(others)
                    break
        if to_split is None:
            return pts, tri
        pts, tri = _split_edge(pts, tri, *to_split, midmap)
    raise RuntimeError("Could not resolve two-boundary-edge triangles.")


def _boundary_node_lists(pts, lx: float, ly: float, tol=1e-10) -> list:
    ids = np.arange(1, pts.shape[0] + 1, dtype=int)

    def sorted_ids(mask, col, reverse=False):
        idx = np.where(mask)[0]
        order = np.argsort(pts[idx, col])
        if reverse:
            order = order[::-1]
        return ids[idx[order]].tolist()

    return [
        sorted_ids(np.abs(pts[:, 1])        <= tol, 0),          # bottom
        sorted_ids(np.abs(pts[:, 0] - lx)   <= tol, 1),          # right
        sorted_ids(np.abs(pts[:, 1] - ly)   <= tol, 0, True),    # top
        sorted_ids(np.abs(pts[:, 0])         <= tol, 1, True),    # left
    ]


def _write_nlist(path: Path, pts):
    with open(path, "w") as f:
        f.write(f"{pts.shape[0]}\n")
        for i, (x, y) in enumerate(pts, start=1):
            f.write(f"{i}\t0\t0\t{x:.6f} {y:.6f} {0.0:.6f}\n")


def _write_elist(path: Path, tri):
    with open(path, "w") as f:
        f.write(f"{tri.shape[0]}\n")
        for e, (a, b, c) in enumerate(tri, start=1):
            f.write(f"1\t1\t0\t0\t0\t0\t0\t0\t4\t0\t{e}\t{a+1}\t{b+1}\t{c+1}\t{c+1}\n")


def _write_blist(path: Path, edges: list):
    bset = set()
    for e in edges:
        bset.update(e)
    with open(path, "w") as f:
        f.write("4\n")
        f.write(f"{len(bset)}\n")
        for e in edges:
            f.write(f"{len(e)}\n")
        for e in edges:
            f.write(" ".join(map(str, e)) + "\n")


# ---------------------------------------------------------------------------
# residual monitor helpers  (used by cmd_run when --monitor residual is set)
# ---------------------------------------------------------------------------

# Embedded script run as a subprocess to own the tornado/WebAgg event loop.
# Main biofem process writes plot data to a JSON file; this script reads it.
_WEBAGG_DISPLAY_SCRIPT = r"""
import sys, json, time, threading
port      = int(sys.argv[1])
data_file = sys.argv[2]
import matplotlib as mpl
mpl.use("WebAgg")
mpl.rcParams["webagg.port"] = port
mpl.rcParams["webagg.open_in_browser"] = False
import matplotlib.pyplot as plt
fig, ax = plt.subplots(figsize=(10, 5))

def _update():
    # Wait for tornado to start before first draw attempt.
    time.sleep(3)
    while True:
        try:
            with open(data_file) as f:
                d = json.load(f)
            rn = d.get("rn", [])
            ax.cla()
            if rn:
                ax.semilogy(range(len(rn)), rn, "b.-", linewidth=1.2, markersize=6)
            ax.set_xlabel("Newton iteration (cumulative)")
            ax.set_ylabel("||R||")
            ax.set_title("SNES convergence — all Newton iterations")
            ax.grid(True, which="both", alpha=0.3)
            fig.tight_layout()
            # Schedule the canvas flush in tornado's own thread (thread-safe).
            try:
                from matplotlib.backends.backend_webagg import WebAggApplication
                iol = getattr(WebAggApplication, "ioloop", None)
                if iol is not None:
                    iol.add_callback(fig.canvas.draw)
                else:
                    fig.canvas.draw()
            except Exception:
                fig.canvas.draw()
        except Exception:
            pass
        time.sleep(2)

threading.Thread(target=_update, daemon=True).start()
plt.show()   # blocking — tornado owns this thread; subprocess is killed by parent on exit
"""

# Embedded script that opens a native matplotlib window (Tk/Qt) instead of
# WebAgg. Only usable when a real display is reachable (local X, or ssh -Y/-X
# forwarding) — VS Code's integrated terminal has no DISPLAY, so this is
# skipped there and WebAgg is used instead.
_GUI_DISPLAY_SCRIPT = r"""
import sys, json, time
data_file = sys.argv[1]
import matplotlib
fig = ax = None
errors = []
for backend in ("TkAgg", "Qt5Agg", "QtAgg"):
    try:
        matplotlib.use(backend, force=True)
        import matplotlib.pyplot as plt
        fig, ax = plt.subplots(figsize=(10, 5))
        plt.show(block=False)
        break
    except Exception as e:
        errors.append(f"{backend}: {e}")
        fig = ax = None
        continue
if fig is None:
    print("no usable GUI backend / display —\n  " + "\n  ".join(errors), file=sys.stderr)
    sys.exit(1)   # caller falls back to WebAgg

while True:
    try:
        with open(data_file) as f:
            d = json.load(f)
        rn = d.get("rn", [])
        ax.cla()
        if rn:
            ax.semilogy(range(len(rn)), rn, "b.-", linewidth=1.2, markersize=6)
        ax.set_xlabel("Newton iteration (cumulative)")
        ax.set_ylabel("||R||")
        ax.set_title("SNES convergence — all Newton iterations")
        ax.grid(True, which="both", alpha=0.3)
        fig.tight_layout()
        fig.canvas.draw_idle()
    except Exception:
        pass
    try:
        plt.pause(2.0)   # pumps the GUI event loop while waiting
    except Exception:
        break   # window was closed by the user
"""

def _parse_residual_log(log_file):
    timesteps, snes_iters, rnorms = [], [], []
    try:
        with open(log_file) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                parts = line.split()
                if len(parts) == 3:
                    try:
                        timesteps.append(int(parts[0]))
                        snes_iters.append(int(parts[1]))
                        rnorms.append(float(parts[2]))
                    except ValueError:
                        pass
    except OSError:
        pass
    return timesteps, snes_iters, rnorms


def _draw_snes_plot(ax, rnorms):
    """Single-panel: every SNES Newton iteration's ||R||, across all time steps."""
    ax.cla()
    if rnorms:
        ax.semilogy(range(len(rnorms)), rnorms, "b.-", linewidth=1.2, markersize=6)
    ax.set_xlabel("Newton iteration (cumulative)")
    ax.set_ylabel("||R||")
    ax.set_title("SNES convergence — all Newton iterations")
    ax.grid(True, which="both", alpha=0.3)


def _run_with_monitor(shell_cmd, run_dir, port, out_dir="output"):
    """Run solver as Popen and live-plot SNES residuals.

    WebAgg runs in a completely separate subprocess so its blocking tornado
    event loop never touches the main process.  Main process: submits job,
    polls log, prints status, handles Ctrl+C — no matplotlib involved at all.
    Final PNG saved via standalone Agg figure.
    """
    import sys as _sys
    import json as _json
    import tempfile as _tmp
    import time as _time
    run_dir  = Path(run_dir)
    log_file = run_dir / out_dir / "residual.log"
    png_file = run_dir / out_dir / "residual_monitor.png"

    # ── launch a live-plot display subprocess ────────────────────────────────
    # Prefer a native GUI window (local X11, or ssh -X/-Y forwarding) since
    # that's usable outside a browser. Only try it when DISPLAY is actually
    # set — VS Code's integrated terminal has no DISPLAY, so this is skipped
    # there and we fall straight to WebAgg (a local server + browser tab).
    data_file    = Path(_tmp.mktemp(suffix="_biofem_plot.json"))
    display_proc = None
    use_webagg   = False
    use_gui      = False
    try:
        import matplotlib  # check availability only; do NOT import pyplot here
        data_file.write_text("{}")

        if os.environ.get("DISPLAY"):
            try:
                display_proc = subprocess.Popen(
                    [_sys.executable, "-c", _GUI_DISPLAY_SCRIPT, str(data_file)],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.PIPE,
                    start_new_session=True,
                )
                _time.sleep(1.5)   # give the GUI backend time to open the window
                if display_proc.poll() is not None:
                    err = display_proc.stderr.read().decode(errors="replace").strip()
                    raise RuntimeError(err or "GUI display process exited immediately")
                use_gui = True
                print("[biofem] live plot → native window")
            except Exception as e:
                print(f"[biofem] native window unavailable ({e}); falling back to WebAgg")
                if display_proc is not None:
                    display_proc.terminate()
                    display_proc = None

        if not use_gui:
            display_proc = subprocess.Popen(
                [_sys.executable, "-c", _WEBAGG_DISPLAY_SCRIPT, str(port), str(data_file)],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.PIPE,
                start_new_session=True,   # isolate from terminal Ctrl+C signal
            )
            _time.sleep(2.5)              # give tornado time to bind the port
            if display_proc.poll() is not None:
                err = display_proc.stderr.read().decode(errors="replace").strip()
                raise RuntimeError(err or "display process exited immediately")
            use_webagg = True
            print(f"[biofem] live plot → http://localhost:{port}")
            print(f"[biofem] (VSCode: Ports tab → forward {port}, then open in browser)")
    except Exception as e:
        if display_proc is not None:
            display_proc.terminate()
            display_proc = None
        print(f"[biofem] live plot unavailable ({e})")
        print(f"[biofem] running without live plot — PNG saved to {png_file}")

    # ── start solver / sbatch ─────────────────────────────────────────────────
    if shell_cmd.startswith("sbatch "):
        proc = subprocess.Popen(shell_cmd.split(), cwd=run_dir)
        print(f"[biofem] job submitted, monitoring {log_file} ...")
    else:
        proc = subprocess.Popen(["bash", "--login", "-c", shell_cmd], cwd=run_dir)
        print(f"[biofem] solver started (PID {proc.pid})")

    # ── monitor loop ──────────────────────────────────────────────────────────
    last_size = -1
    try:
        while True:
            done = proc.poll() is not None

            if log_file.exists():
                sz = log_file.stat().st_size
                if sz != last_size:
                    last_size = sz
                    ts, si, rn = _parse_residual_log(log_file)
                    if rn:
                        print(f"\r[biofem] step={ts[-1]}  newton={si[-1]}  rnorm={rn[-1]:.3e}",
                              end="", flush=True)
                        if use_gui or use_webagg:
                            try:
                                data_file.write_text(_json.dumps({"rn": rn}))
                            except Exception:
                                pass

            _time.sleep(2.0)   # Ctrl+C interrupts cleanly here

            if done:
                break
    except KeyboardInterrupt:
        print("\n[biofem] interrupted — terminating solver ...")
        proc.terminate()
        proc.wait()

    # ── shut down display subprocess ──────────────────────────────────────────
    if display_proc is not None:
        try:
            display_proc.terminate()
            display_proc.wait(timeout=3)
        except Exception:
            pass
    try:
        data_file.unlink(missing_ok=True)
    except Exception:
        pass

    # ── final PNG via standalone Agg figure ───────────────────────────────────
    ts, si, rn = _parse_residual_log(log_file)
    if rn:
        try:
            from matplotlib.backends.backend_agg import FigureCanvasAgg as _FCA
            from matplotlib.figure import Figure as _Fig
            fig2 = _Fig(figsize=(10, 5))
            _FCA(fig2)
            ax2 = fig2.add_subplot(1, 1, 1)
            _draw_snes_plot(ax2, rn)
            fig2.tight_layout()
            fig2.savefig(png_file, dpi=100)
            print(f"\n[biofem] plot saved → {png_file}")
        except Exception as e:
            print(f"\n[biofem] PNG save failed: {e}")

    if proc.returncode not in (0, -15):  # -15 = SIGTERM (our own interrupt)
        raise subprocess.CalledProcessError(proc.returncode, shell_cmd)


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        prog="biofem",
        description="BioFEM-IA solver CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Build first (from repo root):
  make build                  # dmplex backend (default)
  make build ARGS="-DBIOFEM_CUDA=ON"   # cuda backend
  make install                # symlink biofem into ~/.local/bin

Run:
  biofem run                                  # submit to SLURM (default)
  biofem run --local                          # run in this terminal now
  biofem run --np 8 --account myaccount       # SLURM, 8 tasks
  biofem run --backend cuda --dry-run         # preview jobfile
  biofem sweep --backend dmplex --nx 64,128,256 --ny 48,96,192 --ntasks 1,4,8,16
""",
    )
    parser.add_argument("--version", action="version", version=f"biofem {__version__}")

    sub = parser.add_subparsers(dest="command", metavar="COMMAND")

    # run
    p_run = sub.add_parser(
        "run", help="run solver in current case directory",
        description=(
            "Run the solver from the current directory (must contain control.dat).\n"
            "On a SLURM cluster the job is submitted via sbatch unless you are\n"
            "already inside an interactive allocation."
        ),
    )
    p_run.add_argument("--backend", default="dmplex", choices=list(BACKENDS),
                       help="solver backend (default: dmplex)")
    p_run.add_argument("--np", type=int, default=1,
                       help="MPI task count (default: 1)")
    p_run.add_argument("--time", default="01:00:00",
                       help="SLURM time limit (default: 01:00:00)")
    p_run.add_argument("--account", default="",
                       help="SLURM account (overrides site.cfg)")
    p_run.add_argument("--local", action="store_true",
                       help="run directly in this terminal instead of submitting to SLURM")
    p_run.add_argument("--monitor", default="",
                       help="comma-separated monitors to enable, e.g. residual")
    p_run.add_argument("--petsc-opts", default="",
                       help="extra PETSc flags appended after the executable, e.g. \"-out_dir out_n2\"")
    p_run.add_argument("--slurm-output", default="",
                       help="SLURM output file path (overrides default biofem_<backend>_%%j.out)")
    p_run.add_argument("--wait", action="store_true",
                       help="block until the submitted SLURM job completes (passes --wait to sbatch)")
    p_run.add_argument("--port", type=int, default=8988,
                       help="WebAgg port for live residual plot (--monitor residual, default: 8988)")
    p_run.add_argument("--dry-run", action="store_true",
                       help="print jobfile or shell command without executing")

    # sweep
    p_sw = sub.add_parser(
        "sweep", help="generate mesh cases and submit parameter sweep",
        description=(
            "Generate rectangular Delaunay meshes for each (nx, ny) pair,\n"
            "write case directories under --output-dir, and submit one\n"
            "SLURM job per (mesh, ntasks) combination."
        ),
    )
    p_sw.add_argument("--backend", default="dmplex", choices=list(BACKENDS),
                      help="solver backend (default: dmplex)")
    p_sw.add_argument("--nx", default="64",
                      help="comma-separated nx values, e.g. 64,128,256")
    p_sw.add_argument("--ny", default="48",
                      help="comma-separated ny values (must match --nx length)")
    p_sw.add_argument("--ntasks", default="1",
                      help="comma-separated MPI task counts, e.g. 1,4,8,16")
    p_sw.add_argument("--lx", type=float, default=1.2, help="domain length x (default: 1.2)")
    p_sw.add_argument("--ly", type=float, default=0.9, help="domain length y (default: 0.9)")
    p_sw.add_argument("--output-dir", default="./sweep",
                      help="directory for generated case folders (default: ./sweep)")
    p_sw.add_argument("--account", default="",
                      help="SLURM account (overrides site.cfg)")
    p_sw.add_argument("--min-elems-per-task", type=int, default=100,
                      help="skip (mesh, ntasks) with fewer elements/task (default: 100)")
    p_sw.add_argument("--failed-only", action="store_true",
                      help="only submit runs whose existing output shows a failure")
    p_sw.add_argument("--rerun-completed", action="store_true",
                      help="re-submit jobs that already completed successfully")
    p_sw.add_argument("--dry-run", action="store_true",
                      help="generate jobfiles but do not submit")

    args = parser.parse_args()
    if args.command is None:
        parser.print_help()
        sys.exit(0)

    {"run": cmd_run, "sweep": cmd_sweep}[args.command](args)


if __name__ == "__main__":
    main()
